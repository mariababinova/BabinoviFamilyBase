{
  "name": "meds-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:data": "node scripts/generate-data.mjs",
    "validate:data": "node scripts/generate-data.mjs --validate",
    "validate:ops": "node scripts/validate-operational-layer.mjs",
    "validate:assets": "node scripts/validate-assets.mjs",
    "agent:intake": "node scripts/intake-agent.mjs scan",
    "agent:promote": "node scripts/intake-agent.mjs promote",
    "agent:metrics": "node scripts/metrics-agent.mjs",
    "agent:tasks": "node scripts/tasks-agent.mjs",
    "agent:doctor-summaries": "node scripts/doctor-summary-agent.mjs",
    "dev:data": "node scripts/generate-data.mjs --dev-assets",
    "dev": "astro dev --host 127.0.0.1",
    "check": "astro check",
    "prebuild": "node scripts/validate-operational-layer.mjs && node scripts/doctor-summary-agent.mjs && node scripts/generate-data.mjs && node scripts/validate-assets.mjs",
    "build": "astro build && node scripts/copy-documents.mjs",
    "preview": "astro preview --host 127.0.0.1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@openai/chatkit": "^1.7.0",
    "@vercel/node": "^5.5.0",
    "astro": "^5.15.6",
    "gray-matter": "^4.0.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {}
}
