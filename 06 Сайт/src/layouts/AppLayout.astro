---
import "../styles/global.css";
import MedicalChatWidget from "../components/MedicalChatWidget.astro";
import { dashboard, pageHref } from "../lib/ui";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Семейная медицинская база" } = Astro.props;
const navItems = [
  { href: pageHref("/"), label: "Сегодня" },
  { href: pageHref("/upload"), label: "Загрузка" },
];
const people = dashboard.people;
const currentPath = Astro.url.pathname;

function isActiveNav(href: string) {
  const normalizePath = (value: string) => (value.length > 1 ? value.replace(/\/$/, "") : value);
  const path = normalizePath(new URL(href, Astro.url).pathname);
  const activePath = normalizePath(currentPath);
  return activePath === path || (path.endsWith("/upload") && activePath.startsWith(`${path}`));
}

function isActivePerson(person: { href: string }) {
  const normalizePath = (value: string) => (value.length > 1 ? value.replace(/\/$/, "") : value);
  const path = normalizePath(new URL(person.href, Astro.url).pathname);
  const activePath = normalizePath(currentPath);
  return activePath === path || activePath.startsWith(`${path}/`);
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script
      is:inline
      src="https://cdn.platform.openai.com/deployments/chatkit/chatkit.js"
      async
    ></script>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar" aria-label="Основная навигация">
        <a class="brand" href={pageHref("/")}>
          <span class="brand-mark">Б</span>
          <span>
            <strong>База Бабиновых</strong>
            <small>семейная база знаний</small>
          </span>
        </a>
        <nav class="side-nav">
          <a class:list={["nav-link", isActiveNav(navItems[0].href) && "active"]} href={navItems[0].href}>
            {navItems[0].label}
          </a>
          <div class="nav-group">
            <span class="nav-group-label">Медкарты</span>
            {people.map((person) => (
              <a class:list={["person-pill", isActivePerson(person) && "active"]} href={person.href}>
                {person.photo ? (
                  <img src={pageHref(person.photo)} alt="" loading="lazy" />
                ) : (
                  <span class="person-initial" aria-hidden="true">{person.name.slice(0, 1)}</span>
                )}
                <span>{person.name}</span>
              </a>
            ))}
          </div>
          <a class:list={["nav-link", isActiveNav(navItems[1].href) && "active"]} href={navItems[1].href}>
            {navItems[1].label}
          </a>
        </nav>
        <div class="side-section side-section-secondary">
          <span class="side-label">Служебное</span>
          <a class="person-pill" href={pageHref("/upload-queue")}>Очередь загрузки</a>
        </div>
      </aside>
      <div class="main-area">
        <header class="topbar">
          <form action={pageHref("/search")} method="get" class="search-form">
            <label class="sr-only" for="global-search">Поиск</label>
            <input id="global-search" type="search" name="q" placeholder="Поиск по базе: ферритин Маши, документы Ники, онкология Александр" />
          </form>
          <div class="topbar-meta">
            <span>Обновлено {new Date(dashboard.generatedAt).toLocaleDateString("ru-RU")}</span>
            <a class="topbar-avatar" href={pageHref("/owner-guide")} aria-label="Служебный раздел">Б</a>
          </div>
        </header>
        <main class="content">
          <slot />
        </main>
      </div>
    </div>
    <nav class="bottom-nav" aria-label="Быстрая навигация">
      <a href={pageHref("/")}>Сегодня</a>
      <a href={`${pageHref("/")}#medcards`}>Медкарты</a>
      <a href={pageHref("/upload")}>Загрузка</a>
    </nav>
    <MedicalChatWidget />
  </body>
</html>
