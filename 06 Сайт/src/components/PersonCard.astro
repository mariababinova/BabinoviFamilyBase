---
import MetricIcon from "./MetricIcon.astro";
import { ageText, formatDateShort, pageHref } from "../lib/ui";

const { person } = Astro.props;
const taskCount = person.nextTasks?.length || 0;
const metricCount = person.keyMetrics?.length || 0;
---

<article class="card person-card">
  <div class="person-card-top">
    <a class="person-avatar-link" href={person.href} aria-label={`Открыть профиль ${person.name}`}>
      {person.photo ? (
        <img class="person-avatar large" src={pageHref(person.photo)} alt={person.name} loading="lazy" />
      ) : (
        <span class="person-avatar large fallback" aria-hidden="true">{person.name.slice(0, 1)}</span>
      )}
    </a>
    <div>
      <h3><a href={person.href}>{person.name}</a></h3>
      <p>{ageText(person.birthDate) || person.importantStatus || "Профиль"}</p>
    </div>
  </div>
  <dl class="mini-stats person-stats">
    <div><dt>События</dt><dd>{person.eventCount}</dd></div>
    <div><dt>Документы</dt><dd>{person.documentCount || 0}</dd></div>
    <div><dt>Задачи</dt><dd>{taskCount}</dd></div>
    <div>
      <dt>Показатели</dt>
      <dd>{metricCount}</dd>
    </div>
  </dl>
  {person.latestWeight && (
    <a class="soft-row compact metric-soft-row" href={person.weightMetric?.href || pageHref("/metrics")}>
      <MetricIcon metricName="Вес" status="normal" class="compact" />
      <span>Вес на {formatDateShort(person.latestWeight.date)}</span>
      <strong>{person.latestWeight.displayValue}</strong>
    </a>
  )}
  {person.latestEvent && (
    <a class="soft-row" href={person.latestEvent.href}>
      <span>Последнее событие</span>
      <strong>{formatDateShort(person.latestEvent.date)} · {person.latestEvent.specialty}</strong>
    </a>
  )}
  {person.nextTasks?.[0] && (
    <a class="soft-row accent" href={person.nextTasks[0].sourceHref || person.nextTasks[0].href}>
      <span>Ближайшая задача</span>
      <strong>{person.nextTasks[0].actionText}</strong>
    </a>
  )}
  <a class="button secondary inline-button" href={person.href}>Открыть профиль</a>
</article>

