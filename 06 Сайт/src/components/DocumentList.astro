---
import { formatDateShort } from "../lib/ui";

interface DocumentItem {
  href: string;
  fileName: string;
  displayName?: string;
  person?: string;
  date?: string;
  specialty?: string;
  extension?: string;
  isLinkedToEvent: boolean;
  linkStatusLabel: string;
  publicUrl?: string;
  encryptedUrl?: string;
  isOriginalPublic?: boolean;
}

const { documents, compact = false } = Astro.props as { documents: DocumentItem[]; compact?: boolean };
---

<div class="document-list">
  {documents.map((document) => (
    <article class:list={["document-row", compact && "compact"]}>
      <div>
        <div class="document-meta">
          <span class="chip muted">{formatDateShort(document.date)}</span>
          {document.person && <span class="chip">{document.person}</span>}
          {document.specialty && <span class="chip">{document.specialty}</span>}
          {document.extension && <span class="chip muted">{document.extension.toUpperCase()}</span>}
        </div>
        <h3><a href={document.href}>{document.displayName || document.fileName}</a></h3>
      </div>
      <div class="document-actions">
        <span class:list={["status-pill", document.isLinkedToEvent ? "linked" : "unlinked"]}>{document.linkStatusLabel}</span>
        {document.publicUrl ? (
          <a class="button secondary" href={document.publicUrl} target="_blank" rel="noreferrer">Открыть</a>
        ) : document.encryptedUrl ? (
          <a class="button secondary" href={document.href}>Открыть</a>
        ) : (
          <span class="status-pill muted">Оригинал не публикуется</span>
        )}
      </div>
    </article>
  ))}
  {documents.length === 0 && <p class="empty">Документов нет.</p>}
</div>
