---
import { formatDateShort, groupTasks } from "../lib/ui";

const { tasks } = Astro.props;
const taskItems = tasks || [];
const groups = groupTasks(taskItems);
---

<section class="task-board" data-task-board>
  {groups.map((group) => (
    <div class:list={["task-column", group.id]} data-task-column={group.id} hidden={group.tasks.length === 0}>
      <h3>{group.title}</h3>
      <div class="task-list" data-task-list>
        {group.tasks.map((task) => (
          <a
            class:list={["task-card", task.state.bucket]}
            href={task.href || task.sourceHref}
            data-task-card
            data-due-date={task.dueDate || ""}
            aria-label={`Открыть задачу: ${task.actionText || task.title || "Задача"}`}
          >
            <strong>{task.actionText || task.title || "Задача"}</strong>
            {(task.dueDate || task.specialty) && (
              <span class="task-meta">
                {task.dueDate && <time datetime={task.dueDate}>{formatDateShort(task.dueDate)}</time>}
                {task.specialty && <span>{task.specialty}</span>}
              </span>
            )}
          </a>
        ))}
      </div>
    </div>
  ))}
  {taskItems.length === 0 && <p class="empty">Задач пока нет.</p>}
  <script is:inline>
    (() => {
    const dayMs = 24 * 60 * 60 * 1000;
    const stateLabels = {
      overdue: "Просрочено",
      week: "На этой неделе",
      month: "В этом месяце",
      later: "Позже",
      unknown: "Без даты",
    };

    function dateOnly(value) {
      if (!value) return null;
      const parts = value.split("-").map(Number);
      if (parts.length !== 3 || parts.some(Number.isNaN)) return null;
      const date = new Date(parts[0], parts[1] - 1, parts[2]);
      if (
        date.getFullYear() !== parts[0] ||
        date.getMonth() !== parts[1] - 1 ||
        date.getDate() !== parts[2]
      ) {
        return null;
      }
      return date;
    }

    function taskState(dueDate) {
      const due = dateOnly(dueDate);
      if (!due) return { bucket: "unknown", label: stateLabels.unknown };

      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const diffDays = Math.round((due.getTime() - today.getTime()) / dayMs);
      if (diffDays < 0) return { bucket: "overdue", label: stateLabels.overdue };
      if (diffDays <= 7) return { bucket: "week", label: stateLabels.week };
      if (diffDays <= 31) return { bucket: "month", label: stateLabels.month };
      return { bucket: "later", label: stateLabels.later };
    }

    function refreshTaskBoard(board) {
      const columns = new Map(
        Array.from(board.querySelectorAll("[data-task-column]")).map((column) => [
          column.getAttribute("data-task-column"),
          column,
        ]),
      );
      const cards = Array.from(board.querySelectorAll("[data-task-card]"));

      for (const card of cards) {
        const state = taskState(card.getAttribute("data-due-date"));
        const targetList = columns.get(state.bucket)?.querySelector("[data-task-list]");
        targetList?.append(card);
      }

      for (const column of columns.values()) {
        const list = column.querySelector("[data-task-list]");
        const sortedCards = Array.from(list?.querySelectorAll("[data-task-card]") || []).sort((a, b) => {
          const aDate = a.getAttribute("data-due-date") || "9999-12-31";
          const bDate = b.getAttribute("data-due-date") || "9999-12-31";
          return aDate.localeCompare(bDate);
        });
        sortedCards.forEach((card) => list?.append(card));
        column.toggleAttribute("hidden", sortedCards.length === 0);
      }
    }

    document.querySelectorAll("[data-task-board]").forEach(refreshTaskBoard);
    })();
  </script>
</section>
