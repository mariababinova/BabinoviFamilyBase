---
import { getMetricIcon, metricStatusTone } from "../lib/ui";

interface Props {
  metricName?: string;
  status?: string;
  statusLabel?: string;
  tone?: string;
  class?: string;
}

const {
  metricName = "",
  status = "",
  statusLabel = "",
  tone,
  class: className = "",
} = Astro.props;

const metricIcon = getMetricIcon(metricName);
const icon = metricIcon.icon;
const toneClass = tone || metricStatusTone(status, statusLabel);
const ariaLabel = `${metricIcon.label}: ${metricName || "показатель"}`;
---

<span class:list={["metric-icon", `metric-icon-${icon}`, toneClass, className]} role="img" aria-label={ariaLabel}>
  {icon === "blood-drop" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 3.5C9.2 7.2 6.4 10.7 6.4 14a5.6 5.6 0 0 0 11.2 0C17.6 10.7 14.8 7.2 12 3.5Z" />
      <path d="M9.4 14.2a2.8 2.8 0 0 0 3.7 2.6" />
    </svg>
  )}

  {icon === "red-cell" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <ellipse cx="12" cy="12" rx="7.6" ry="5.8" />
      <ellipse cx="12" cy="12" rx="3.4" ry="2.1" />
      <path d="M5.4 9.4c1.6-2 4-3 6.6-3s5 1 6.6 3" />
    </svg>
  )}

  {icon === "thyroid" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M9.4 5.5C6.8 6.4 5.2 8.7 5.2 12c0 3.2 1.5 5.7 3.9 6.7 1.3.5 2.4-.5 2.4-2V7.4c0-1.4-.8-2.3-2.1-1.9Z" />
      <path d="M14.6 5.5c2.6.9 4.2 3.2 4.2 6.5 0 3.2-1.5 5.7-3.9 6.7-1.3.5-2.4-.5-2.4-2V7.4c0-1.4.8-2.3 2.1-1.9Z" />
      <path d="M11.5 9.4h1M11.5 14.6h1" />
    </svg>
  )}

  {icon === "sun" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="4.2" />
      <path d="M12 2.8v2.5M12 18.7v2.5M4.2 4.2 6 6M18 18l1.8 1.8M2.8 12h2.5M18.7 12h2.5M4.2 19.8 6 18M18 6l1.8-1.8" />
    </svg>
  )}

  {icon === "capsule" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <g transform="rotate(-35 12 12)">
        <rect x="4.5" y="8.4" width="15" height="7.2" rx="3.6" />
        <path d="M12 8.4v7.2" />
      </g>
    </svg>
  )}

  {icon === "molecule" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="7" cy="12" r="2.6" />
      <circle cx="16.7" cy="7" r="2.4" />
      <circle cx="17" cy="17" r="2.4" />
      <path d="m9.4 10.8 5.1-2.6M9.4 13.2l5.2 2.6" />
    </svg>
  )}

  {icon === "heart-vessel" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 19.2s-6.5-3.8-7.7-8.1C3.5 8.2 5.2 6 7.8 6c1.6 0 2.8.8 4.2 2.4C13.4 6.8 14.6 6 16.2 6c2.6 0 4.3 2.2 3.5 5.1C18.5 15.4 12 19.2 12 19.2Z" />
      <path d="M5.8 12.2h3l1.1-2.1 2.2 4.6 1.2-2.5h4.8" />
    </svg>
  )}

  {icon === "liver" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4.5 13.2c.3-4.1 3.2-6.9 7.8-6.9 2.9 0 5.3.8 7.2 2.4 1.4 1.2 1.2 3.4-.3 4.4-2.2 1.5-4.8 2.3-7.8 2.3H8.2c-1.9 0-3.1-.8-3.7-2.2Z" />
      <path d="M12.7 6.4v8.8M12.7 11.2h3.8" />
    </svg>
  )}

  {icon === "kidney" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M9.2 4.8c-2.5.5-4 3-3.9 6.5.1 4 2.2 7.1 5 7.1 1.7 0 2.8-1.4 2.2-3.1-.4-1.1-1.3-1.5-2.4-1.9-1.1-.4-1.6-1.1-1.6-2.1 0-1.1.8-1.8 1.8-2.1 1.4-.4 2.2-1.4 1.8-2.8-.3-1.2-1.3-1.8-2.9-1.6Z" />
      <path d="M14.8 4.8c2.5.5 4 3 3.9 6.5-.1 4-2.2 7.1-5 7.1-1.7 0-2.8-1.4-2.2-3.1.4-1.1 1.3-1.5 2.4-1.9 1.1-.4 1.6-1.1 1.6-2.1 0-1.1-.8-1.8-1.8-2.1-1.4-.4-2.2-1.4-1.8-2.8.3-1.2 1.3-1.8 2.9-1.6Z" />
    </svg>
  )}

  {icon === "molecule-chain" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="5.8" cy="13.8" r="2.2" />
      <circle cx="12" cy="8.6" r="2.2" />
      <circle cx="18.2" cy="13.8" r="2.2" />
      <path d="m7.5 12.4 2.8-2.3M13.7 10.1l2.8 2.3M8 15.1h8" />
    </svg>
  )}

  {icon === "coagulation" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M10 4.2C7.8 7.1 5.9 9.7 5.9 12.1A4.1 4.1 0 0 0 10 16.2a4.1 4.1 0 0 0 4.1-4.1c0-2.4-1.9-5-4.1-7.9Z" />
      <path d="M13.4 15.5 19 20M16.2 15.2l-1.1 3.4M18.9 17.4l-3.3.9" />
    </svg>
  )}

  {icon === "scale" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="5" y="4.8" width="14" height="14.4" rx="3.2" />
      <path d="M9 9.2a4.6 4.6 0 0 1 6 0M12 9.4l1.5 2.4" />
      <path d="M8.2 16.2h7.6" />
    </svg>
  )}

  {icon === "blood-pressure" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <rect x="4.4" y="6.2" width="8.2" height="11.6" rx="2" />
      <path d="M12.6 9.2h2.8a3.2 3.2 0 0 1 3.2 3.2v.6M18.6 13v3.7" />
      <circle cx="18.6" cy="18.2" r="1.8" />
      <path d="M6.6 11.8h3.8" />
    </svg>
  )}

  {icon === "pulse" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M3.4 12h4.1l1.6-4.4 3.1 9.1 2-4.7h6.4" />
      <path d="M12 19.2s-5.2-3-6.6-6.2" />
    </svg>
  )}

  {icon === "inflammation" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="6.8" />
      <path d="M12 7.8v8.4M7.8 12h8.4" />
      <path d="M5.2 5.2 7 7M17 17l1.8 1.8M18.8 5.2 17 7M7 17l-1.8 1.8" />
    </svg>
  )}

  {icon === "lab" && (
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M9 4.5h6M10 4.8v5.3l-4.1 6.7c-.9 1.5.2 3.4 1.9 3.4h8.4c1.7 0 2.8-1.9 1.9-3.4L14 10.1V4.8" />
      <path d="M8.2 16h7.6" />
    </svg>
  )}
</span>
