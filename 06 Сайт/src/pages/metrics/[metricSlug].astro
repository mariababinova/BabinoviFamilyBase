---
import AppLayout from "../../layouts/AppLayout.astro";
import MetricIcon from "../../components/MetricIcon.astro";
import { dashboard, formatDate, formatDateShort } from "../../lib/ui";

export function getStaticPaths() {
  return (dashboard.metricGroups || []).map((group) => ({
    params: { metricSlug: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
const latest = group.latest;
const questions = group.doctorQuestions || [];

function statusBadgeLabel(record: any) {
  if (!record) return "Нет данных";
  return record.compactAssessmentLabel || record.assessmentLabel || "Нет данных";
}

function eventSource(record: any) {
  return {
    href: typeof record?.eventHref === "string" ? record.eventHref : "",
    title: typeof record?.eventTitle === "string" ? record.eventTitle : "",
  };
}

const latestStatusLabel = statusBadgeLabel(latest);
---

<AppLayout title={`${group.metricLabel} · Показатели`}>
  <section class="page-header">
    <div class="metric-page-title">
      <MetricIcon metricName={group.metricLabel} status={latest?.assessmentStatus} statusLabel={latestStatusLabel} class="large" />
      <div>
        <p class="eyebrow">{group.person}</p>
        <h1>{group.metricLabel}</h1>
        <p>История значений из подтвержденных записей. Это не медицинская интерпретация, а удобная сводка для просмотра динамики и подготовки вопросов врачу.</p>
      </div>
    </div>
  </section>

  <section class="metrics-summary">
    <article class:list={["card", "metric-summary-card", latest?.assessmentStatus || "unknown"]} data-assessment-label={statusBadgeLabel(latest)}>
      <div class="metric-summary-head">
        <MetricIcon metricName={group.metricLabel} status={latest?.assessmentStatus} statusLabel={latestStatusLabel} />
        <div>
          <span class:list={["metric-reference-badge", latest?.assessmentStatus || "unknown"]}>
            {latestStatusLabel}
          </span>
          <span class="muted-text">Последнее значение</span>
        </div>
      </div>
      <strong>{latest?.displayValue || "Нет данных"}</strong>
      {latest && <small>{formatDate(latest.date)}</small>}
    </article>
    <article class="card">
      <span class="muted-text">Референс последней записи</span>
      <strong>{latest?.referenceDisplay || "Нет данных"}</strong>
      {latest?.labName && <small>{latest.labName}</small>}
    </article>
    <article class="card">
      <span class="muted-text">Динамика</span>
      <strong>{group.trendLabel || (group.count > 1 ? "есть история" : "одно значение")}</strong>
      <small>{group.count} записей</small>
    </article>
  </section>

  <section class="detail-grid">
    <article class="card">
      <h2>История</h2>
      <div class="metric-table-wrap compact">
        <table class="metric-table">
          <thead>
            <tr>
              <th>Дата</th>
              <th>Значение</th>
              <th>Статус</th>
              <th>Референс</th>
              <th>Источник</th>
            </tr>
          </thead>
          <tbody>
            {[...group.records].reverse().map((record) => {
              const source = eventSource(record);

              return (
                <tr>
                  <td>{formatDateShort(record.date)}</td>
                  <td>
                    <span class="metric-name-cell">
                      <MetricIcon
                        metricName={group.metricLabel}
                        status={record.assessmentStatus}
                        statusLabel={record.compactAssessmentLabel || record.assessmentLabel}
                        class="compact"
                      />
                      <strong>{record.displayValue}</strong>
                    </span>
                  </td>
                  <td><span class:list={["metric-status", record.assessmentStatus]}>{record.assessmentLabel}</span></td>
                  <td>{record.referenceDisplay}</td>
                  <td>{source.href ? <a href={source.href}>{source.title || "событие"}</a> : <span class="muted-text">запись</span>}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </article>

    {(group.metricDescription || group.metricMeaning) && (
      <article class="card">
        <h2>Что означает показатель</h2>
        {group.metricDescription && <p>{group.metricDescription}</p>}
        {group.metricMeaning && <p class="muted-text">{group.metricMeaning}</p>}
        <p class="empty">Референсы зависят от лаборатории, метода, единиц измерения и личного контекста, поэтому здесь используется референс из конкретного документа.</p>
      </article>
    )}

    <article class="card">
      <h2>Вопросы врачу</h2>
      {questions.length > 0 ? (
        <ul class="clean-list">
          {questions.map((question) => <li>{question}</li>)}
        </ul>
      ) : (
        <p class="empty">Явных вопросов по данным нет. Можно спросить, какой целевой диапазон важен лично для вас и когда повторять анализ.</p>
      )}
      {latest?.source_text && (
        <div class="note-box">
          <span class="muted-text">Фрагмент источника</span>
          <p>{latest.source_text}</p>
        </div>
      )}
    </article>
  </section>
</AppLayout>
