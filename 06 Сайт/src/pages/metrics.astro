---
import AppLayout from "../layouts/AppLayout.astro";
import MetricIcon from "../components/MetricIcon.astro";
import { dashboard, formatDateShort } from "../lib/ui";

const metricGroups = dashboard.metricGroups || [];
const metricRecords = dashboard.metrics || [];
const people = dashboard.people;
const categories = [...new Set(metricGroups.map((group) => group.metricCategory || "other"))].sort((a, b) =>
  a.localeCompare(b, "ru"),
);
const latestRecords = [...metricRecords].sort((a, b) => String(b.date).localeCompare(String(a.date))).slice(0, 10);
const trendGroups = metricGroups.filter((group) => group.hasTrend);

const categoryLabels: Record<string, string> = {
  lipids: "Липиды",
  carbohydrate_metabolism: "Углеводный обмен",
  thyroid: "Щитовидная железа",
  cbc: "ОАК",
  iron: "Железо",
  vitamins: "Витамины",
  liver: "Печень",
  kidney: "Почки",
  inflammation: "Воспаление",
  cardiovascular: "Сердечно-сосудистое",
  hpv: "ВПЧ",
  urinalysis: "Моча",
  smear: "Мазки",
  body: "Тело",
  custom: "Другое",
};

function categoryLabel(category: string) {
  return categoryLabels[category] || category || "Другое";
}

function statusBadgeLabel(record: any) {
  if (!record) return "Нет данных";
  return record.compactAssessmentLabel || record.assessmentLabel || "Нет данных";
}

function sparkline(records: Array<{ numeric_value?: number | null }>) {
  const points = records
    .filter((record) => record.numeric_value !== null && record.numeric_value !== undefined)
    .map((record) => Number(record.numeric_value));
  if (points.length < 2) return "";
  const min = Math.min(...points);
  const max = Math.max(...points);
  const span = max - min || 1;
  const width = 180;
  const height = 52;
  return points
    .map((value, index) => {
      const x = (index / (points.length - 1)) * width;
      const y = height - ((value - min) / span) * (height - 8) - 4;
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(" ");
}
---

<AppLayout title="Показатели · Медицинская база">
  <section class="page-header">
    <p class="eyebrow">Динамика</p>
    <h1>Показатели</h1>
    <p>Последние значения, история и динамика по анализам. Данные берутся из подтвержденного файла `07 Показатели/metrics.json`.</p>
  </section>

  <section class="metrics-summary">
    <article class="card">
      <span class="muted-text">Записей</span>
      <strong>{metricRecords.length}</strong>
    </article>
    <article class="card">
      <span class="muted-text">Показателей с динамикой</span>
      <strong>{trendGroups.length}</strong>
    </article>
    <article class="card">
      <span class="muted-text">Последнее обновление</span>
      <strong>{latestRecords[0] ? formatDateShort(latestRecords[0].date) : "Нет данных"}</strong>
    </article>
  </section>

  <section class="filter-panel metrics-filter" aria-label="Фильтры показателей">
    <label>
      <span class="side-label">Человек</span>
      <select id="metric-person-filter">
        <option value="">Все</option>
        {people.map((person) => <option value={person.name}>{person.name}</option>)}
      </select>
    </label>
    <label>
      <span class="side-label">Группа</span>
      <select id="metric-category-filter">
        <option value="">Все</option>
        {categories.map((category) => <option value={category}>{categoryLabel(category)}</option>)}
      </select>
    </label>
    <label>
      <span class="side-label">Поиск</span>
      <input id="metric-search" type="search" placeholder="Холестерин, витамин D, ТТГ" />
    </label>
  </section>

  <section>
    <div class="section-title">
      <h2>Все показатели</h2>
      <span class="muted-text">{metricGroups.length} групп</span>
    </div>
    <div class="metric-grid">
      {metricGroups.map((group) => {
        const latest = group.latest;
        const previous = group.previous;
        const points = sparkline(group.records);
        const latestStatusLabel = statusBadgeLabel(latest);
        return (
          <article
            class:list={["card", "metric-card", latest?.assessmentStatus || "unknown"]}
            data-metric-card
            data-person={group.person}
            data-category={group.metricCategory}
            data-name={group.metricLabel.toLowerCase()}
            data-assessment-label={latestStatusLabel}
          >
            <span class:list={["metric-reference-badge", latest?.assessmentStatus || "unknown"]}>
              {latestStatusLabel}
            </span>
            <div class="metric-card-header">
              <div class="metric-title-line">
                <MetricIcon metricName={group.metricLabel} status={latest?.assessmentStatus} statusLabel={latestStatusLabel} />
                <div>
                  <span class="chip muted">{group.person}</span>
                  <h3><a href={group.href}>{group.metricLabel}</a></h3>
                </div>
              </div>
              <span class="count-badge">{group.count}</span>
            </div>
            <div class="metric-latest">
              <strong>{latest?.displayValue || "Нет значения"}</strong>
              <span>{latest ? formatDateShort(latest.date) : ""}</span>
            </div>
            {previous && (
              <p class="metric-delta">
                Предыдущее: {previous.displayValue} от {formatDateShort(previous.date)}
                {group.trendLabel && <span class:list={["delta-pill", group.trendTone]}>{group.trendLabel}</span>}
              </p>
            )}
            {points ? (
              <svg class="sparkline" viewBox="0 0 180 52" role="img" aria-label={`Динамика ${group.metricLabel}`}>
                <polyline points={points} fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            ) : (
              <p class="empty">Пока одно числовое значение или показатель нечисловой.</p>
            )}
            <a class="text-link" href={group.href}>Открыть историю</a>
          </article>
        );
      })}
    </div>
  </section>

  <section>
    <div class="section-title">
      <h2>Последние значения</h2>
    </div>
    <div class="metric-table-wrap">
      <table class="metric-table">
        <thead>
          <tr>
            <th>Дата</th>
            <th>Человек</th>
            <th>Показатель</th>
            <th>Значение</th>
            <th>Статус</th>
            <th>Референс</th>
            <th>Источник</th>
          </tr>
        </thead>
        <tbody>
          {latestRecords.map((record) => (
            <tr>
              <td>{formatDateShort(record.date)}</td>
              <td>{record.person}</td>
              <td>
                <span class="metric-name-cell">
                  <MetricIcon
                    metricName={record.metric_label}
                    status={record.assessmentStatus}
                    statusLabel={record.compactAssessmentLabel || record.assessmentLabel}
                    class="compact"
                  />
                  <span>{record.metric_label}</span>
                </span>
              </td>
              <td><strong>{record.displayValue}</strong></td>
              <td><span class:list={["metric-status", record.assessmentStatus]}>{record.assessmentLabel}</span></td>
              <td>{record.referenceDisplay}</td>
              <td>{record.eventHref ? <a href={record.eventHref}>событие</a> : <span class="muted-text">запись</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <script>
    const personFilter = document.getElementById("metric-person-filter") as HTMLSelectElement | null;
    const categoryFilter = document.getElementById("metric-category-filter") as HTMLSelectElement | null;
    const searchInput = document.getElementById("metric-search") as HTMLInputElement | null;
    const cards = Array.from(document.querySelectorAll("[data-metric-card]")) as HTMLElement[];

    function applyMetricFilters() {
      const person = personFilter?.value || "";
      const category = categoryFilter?.value || "";
      const query = (searchInput?.value || "").trim().toLowerCase();
      for (const card of cards) {
        const matchesPerson = !person || card.dataset.person === person;
        const matchesCategory = !category || card.dataset.category === category;
        const matchesQuery = !query || (card.dataset.name || "").includes(query);
        card.hidden = !(matchesPerson && matchesCategory && matchesQuery);
      }
    }

    personFilter?.addEventListener("change", applyMetricFilters);
    categoryFilter?.addEventListener("change", applyMetricFilters);
    searchInput?.addEventListener("input", applyMetricFilters);
  </script>
</AppLayout>
