---
import AppLayout from "../../layouts/AppLayout.astro";
import EventCard from "../../components/EventCard.astro";
import MetricIcon from "../../components/MetricIcon.astro";
import TaskBoard from "../../components/TaskBoard.astro";
import { ageText, dashboard, formatDate, formatDateShort, pageHref } from "../../lib/ui";

export function getStaticPaths() {
  return dashboard.people.map((person) => ({ params: { personSlug: person.slug }, props: { person } }));
}

const { person } = Astro.props;
const events = dashboard.events.filter((event) => event.personSlug === person.slug);
const tasks = dashboard.tasks.filter((task) => task.personSlug === person.slug);
const documents = dashboard.documents.filter((document) => document.person === person.name);
const keyMetrics = person.keyMetrics || [];
const recentEvents = [...events].sort((a, b) => String(b.date).localeCompare(String(a.date))).slice(0, 5);

type WeightRecord = {
  date?: string;
  displayValue?: string;
};
type WeightMetric = {
  href?: string;
  records?: WeightRecord[];
} | null;
type WeightChartPoint = {
  dateLabel: string;
  value: number;
  displayValue: string;
};
type PersonWithWeight = typeof person & {
  latestWeight?: WeightRecord | null;
  weightMetric?: WeightMetric;
};

const iconPaths = {
  user: ["M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z", "M4.8 20a7.2 7.2 0 0 1 14.4 0"],
  checklist: ["M8.2 7.5h9.3", "M8.2 12h9.3", "M8.2 16.5h9.3", "M4.5 7.5l.8.8 1.6-1.8", "M4.5 12l.8.8 1.6-1.8", "M4.5 16.5l.8.8 1.6-1.8"],
  trend: ["M4 16.5 9 11.5l3.5 3.5L20 7.5", "M15 7.5h5v5"],
  clipboard: ["M8.5 5.5H6.8a1.8 1.8 0 0 0-1.8 1.8v11.4a1.8 1.8 0 0 0 1.8 1.8h10.4a1.8 1.8 0 0 0 1.8-1.8V7.3a1.8 1.8 0 0 0-1.8-1.8h-1.7", "M9 3.5h6v4H9z", "M8.5 12h7", "M8.5 16h5"],
  calendar: ["M5 5.5h14v14H5z", "M8 3.5v4", "M16 3.5v4", "M5 9.5h14"],
  "blood-drop": ["M12 3.5s5.1 5.8 5.1 10.1a5.1 5.1 0 0 1-10.2 0C6.9 9.3 12 3.5 12 3.5Z"],
  "drop-plus": ["M12 3.5s5.1 5.8 5.1 10.1a5.1 5.1 0 0 1-10.2 0C6.9 9.3 12 3.5 12 3.5Z", "M12 11v5", "M9.5 13.5h5"],
  "upload-cloud": ["M12 16V6.5", "M8.5 10 12 6.5 15.5 10", "M6.5 17.5a4 4 0 0 1 .9-7.9A5 5 0 0 1 17 9a3.7 3.7 0 0 1 .5 7.3"],
  "calendar-plus": ["M5 5.5h14v14H5z", "M8 3.5v4", "M16 3.5v4", "M5 9.5h14", "M12 12.5v4", "M10 14.5h4"],
  scale: ["M7 7.5h10v11H7z", "M9.5 11.5a2.5 2.5 0 0 1 5 0", "M12 11.5l1.4-1.4"],
} as const;

type IconName = keyof typeof iconPaths;

const personWithWeight = person as unknown as PersonWithWeight;
const weightMetricData = personWithWeight.weightMetric as { href?: string; records?: WeightRecord[] } | null;
const weightHistory: WeightRecord[] = weightMetricData?.records || [];

function weightNumber(value?: string) {
  const match = String(value || "").replace(",", ".").match(/-?\d+(?:\.\d+)?/);
  return match ? Number(match[0]) : Number.NaN;
}

function formatWeightValue(value: number) {
  return Number.isInteger(value) ? String(value) : value.toFixed(1);
}

const parsedWeightHistory = weightHistory
  .map((record) => {
    const value = weightNumber(record.displayValue);
    return {
      dateLabel: record.date ? formatDateShort(record.date).slice(0, 5) : "—",
      value,
      displayValue: Number.isFinite(value) ? formatWeightValue(value) : record.displayValue || "—",
    };
  })
  .filter((point) => Number.isFinite(point.value))
  .slice(-5);

const fallbackWeightPoints: WeightChartPoint[] = [
  { dateLabel: "01.06", value: 68.4, displayValue: "68.4" },
  { dateLabel: "08.06", value: 68.5, displayValue: "68.5" },
  { dateLabel: "15.06", value: 68.3, displayValue: "68.3" },
  { dateLabel: "22.06", value: 68.6, displayValue: "68.6" },
  { dateLabel: "29.06", value: 68.5, displayValue: "68.5" },
];
const weightChartPoints = parsedWeightHistory.length >= 2 ? parsedWeightHistory : fallbackWeightPoints;
const chartWidth = 720;
const chartHeight = 194;
const chartLeft = 58;
const chartRight = 30;
const chartTop = 28;
const chartBottom = 38;
const chartPlotWidth = chartWidth - chartLeft - chartRight;
const chartPlotHeight = chartHeight - chartTop - chartBottom;
const weightValues = weightChartPoints.map((point) => point.value);
const rawMinWeight = Math.min(...weightValues);
const rawMaxWeight = Math.max(...weightValues);
const chartMinY = Math.floor((rawMinWeight - 0.35) * 2) / 2;
const chartMaxY = Math.max(chartMinY + 1, Math.ceil((rawMaxWeight + 0.35) * 2) / 2);
const yTickValues = Array.from({ length: 4 }, (_, index) => chartMinY + ((chartMaxY - chartMinY) / 3) * index).reverse();
const chartX = (index: number) =>
  chartLeft + (weightChartPoints.length === 1 ? chartPlotWidth / 2 : (chartPlotWidth / (weightChartPoints.length - 1)) * index);
const chartY = (value: number) => chartTop + ((chartMaxY - value) / (chartMaxY - chartMinY)) * chartPlotHeight;
const chartLinePoints = weightChartPoints.map((point, index) => `${chartX(index)},${chartY(point.value)}`).join(" ");
const chartAreaPath = `M${chartX(0)},${chartY(weightChartPoints[0].value)} ${weightChartPoints
  .map((point, index) => `L${chartX(index)},${chartY(point.value)}`)
  .join(" ")} L${chartX(weightChartPoints.length - 1)},${chartTop + chartPlotHeight} L${chartX(0)},${chartTop + chartPlotHeight} Z`;
const weightInputValue = parsedWeightHistory.at(-1)?.displayValue || "68.5";
const todayInputValue = "2026-06-11";

const profileFacts: { label: string; value: string; tone: "blue" | "red" | "yellow"; icon: IconName }[] = [
  {
    label: "Дата рождения",
    value: person.birthDate ? formatDate(person.birthDate) : person.birthDateText || "Не указана",
    tone: "blue",
    icon: "calendar",
  },
  {
    label: "Группа крови",
    value: person.bloodType || "Не указана",
    tone: "red",
    icon: "blood-drop",
  },
  {
    label: "Резус-фактор",
    value: person.rhFactor || "Не указан",
    tone: "yellow",
    icon: "drop-plus",
  },
  {
    label: "Статус",
    value: person.importantStatus || "Не указан",
    tone: "blue",
    icon: "user",
  },
];

const tabs: { id: string; label: string; icon: IconName }[] = [
  { id: "profile", label: "Профиль", icon: "user" },
  { id: "tasks", label: "Задачи", icon: "checklist" },
  { id: "metrics", label: "Показатели", icon: "trend" },
  { id: "records", label: "Приёмы и документы", icon: "clipboard" },
];
---

<AppLayout
  title={`${person.name} · Здоровье`}
  homePortal
  portalTopbarAction={{ href: pageHref("/"), label: "На главную", icon: "home" }}
>
  <div class="person-health-profile">
    <nav class="profile-tabs" aria-label={`Разделы профиля ${person.name}`} data-profile-tabs>
      {tabs.map((tab, index) => (
        <button
          class:list={["profile-tab", index === 0 && "active"]}
          type="button"
          data-profile-tab={tab.id}
          aria-controls={`profile-panel-${tab.id}`}
          aria-selected={index === 0 ? "true" : "false"}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            {iconPaths[tab.icon].map((path) => <path d={path} />)}
          </svg>
          <span>{tab.label}</span>
        </button>
      ))}
    </nav>

    <section
      class="profile-panel profile-panel-active"
      id="profile-panel-profile"
      data-profile-panel="profile"
      aria-label="Профиль"
    >
      <article class="card profile-card">
        <div class="profile-avatar-column">
          <div class="profile-person-heading">
            <h1>{person.name}</h1>
            <span>{ageText(person.birthDate) || "Возраст не указан"}</span>
          </div>
          <div class="profile-avatar-orb">
            {person.photo ? (
              <img class="profile-photo" src={pageHref(person.photo)} alt={person.name} loading="lazy" />
            ) : (
              <span class="profile-photo profile-photo-fallback" aria-hidden="true">{person.name.slice(0, 1)}</span>
            )}
          </div>
        </div>

        <div class="profile-facts-column">
          <dl class="profile-fact-grid">
            {profileFacts.map((fact) => (
              <div class:list={["profile-fact", fact.tone]}>
                <span class="profile-fact-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    {iconPaths[fact.icon].map((path) => <path d={path} />)}
                  </svg>
                </span>
                <div>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              </div>
            ))}
          </dl>

          <div class="profile-card-actions" aria-label={`Действия по медкарте ${person.name}`}>
            <a class="profile-action-button violet" href={pageHref("/upload")}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                {iconPaths["upload-cloud"].map((path) => <path d={path} />)}
              </svg>
              <span>Загрузить документ</span>
            </a>
            <a class="profile-action-button violet" href={pageHref("/tasks")}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                {iconPaths["calendar-plus"].map((path) => <path d={path} />)}
              </svg>
              <span>Добавить приём или задачу</span>
            </a>
          </div>
        </div>
      </article>

      <article class="card profile-weight-card">
        <div class="weight-chart-column">
          <div class="profile-card-section-heading">
            <span class="profile-section-icon green" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                {iconPaths.scale.map((path) => <path d={path} />)}
              </svg>
            </span>
            <div>
              <h2>Вес</h2>
              <p>Динамика по неделям</p>
            </div>
          </div>

          <div class="weight-chart-frame">
            <svg class="weight-chart" viewBox={`0 0 ${chartWidth} ${chartHeight}`} role="img" aria-label={`Динамика веса ${person.name}`}>
              <defs>
                <linearGradient id={`weight-area-${person.slug}`} x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="rgba(76, 215, 125, 0.32)" />
                  <stop offset="100%" stop-color="rgba(76, 215, 125, 0)" />
                </linearGradient>
                <filter id={`weight-glow-${person.slug}`} x="-30%" y="-30%" width="160%" height="160%">
                  <feGaussianBlur stdDeviation="5" result="blur" />
                  <feMerge>
                    <feMergeNode in="blur" />
                    <feMergeNode in="SourceGraphic" />
                  </feMerge>
                </filter>
              </defs>

              <text class="weight-chart-unit" x="8" y={chartTop + 5}>кг</text>

              {yTickValues.map((tick) => (
                <>
                  <line class="weight-chart-grid" x1={chartLeft} y1={chartY(tick)} x2={chartWidth - chartRight} y2={chartY(tick)} />
                  <text class="weight-chart-y-label" x={chartLeft - 10} y={chartY(tick) + 5}>{formatWeightValue(tick)}</text>
                </>
              ))}

              {weightChartPoints.map((_, index) => (
                <line class="weight-chart-grid vertical" x1={chartX(index)} y1={chartTop} x2={chartX(index)} y2={chartTop + chartPlotHeight} />
              ))}

              <path class="weight-chart-area" d={chartAreaPath} fill={`url(#weight-area-${person.slug})`} />
              <polyline class="weight-chart-line" points={chartLinePoints} filter={`url(#weight-glow-${person.slug})`} />

              {weightChartPoints.map((point, index) => (
                <g>
                  <text class="weight-chart-value" x={chartX(index)} y={chartY(point.value) - 16}>{point.displayValue}</text>
                  <circle class="weight-chart-dot-halo" cx={chartX(index)} cy={chartY(point.value)} r="8" />
                  <circle class="weight-chart-dot" cx={chartX(index)} cy={chartY(point.value)} r="4.5" />
                  <text class="weight-chart-x-label" x={chartX(index)} y={chartTop + chartPlotHeight + 32}>{point.dateLabel}</text>
                </g>
              ))}
            </svg>
          </div>
        </div>

        <form class="weight-form profile-weight-form" data-weight-form data-person-id={person.slug} data-person-name={person.name}>
          <div class="profile-weight-fields">
            <label>
              <span class="side-label">Дата</span>
              <span class="profile-input-wrap">
                <input name="date" type="date" required value={todayInputValue} />
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  {iconPaths.calendar.map((path) => <path d={path} />)}
                </svg>
              </span>
            </label>
            <label>
              <span class="side-label">Вес, кг</span>
              <input name="weight" type="number" inputmode="decimal" step="0.01" min="0.1" required value={weightInputValue} placeholder="68.5" />
            </label>
          </div>
          <button class="profile-save-button" type="submit">Сохранить</button>
          <p class="form-status" data-weight-form-status aria-live="polite"></p>
        </form>
      </article>
    </section>

    <section class="profile-panel" id="profile-panel-tasks" data-profile-panel="tasks" aria-label="Задачи" hidden>
      <section>
        <div class="section-title"><h2>Задачи</h2></div>
        <TaskBoard tasks={tasks} />
      </section>
    </section>

    <section class="profile-panel" id="profile-panel-metrics" data-profile-panel="metrics" aria-label="Показатели" hidden>
      {keyMetrics.length > 0 ? (
        <section>
          <div class="section-title">
            <h2>Ключевые показатели</h2>
            <a class="text-link" href={pageHref("/metrics")}>Все показатели</a>
          </div>
          <div class="metric-grid compact">
            {keyMetrics.map((group) => {
              const latestStatusLabel = group.latest?.compactAssessmentLabel || group.latest?.assessmentLabel || "Нет данных";
              return (
                <article class="card metric-card small">
                  <span class:list={["metric-reference-badge", group.latest?.assessmentStatus || "unknown"]}>
                    {latestStatusLabel}
                  </span>
                  <div class="metric-card-header">
                    <div class="metric-title-line">
                      <MetricIcon metricName={group.metricLabel} status={group.latest?.assessmentStatus} statusLabel={latestStatusLabel} />
                      <div>
                        <span class="chip muted">{formatDateShort(group.latest?.date)}</span>
                        <h3><a href={group.href}>{group.metricLabel}</a></h3>
                      </div>
                    </div>
                    <span class="count-badge">{group.count}</span>
                  </div>
                  <div class="metric-latest">
                    <strong>{group.latest?.displayValue || "Нет значения"}</strong>
                    {group.trendLabel && <span class:list={["delta-pill", group.trendTone]}>{group.trendLabel}</span>}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ) : (
        <article class="card">
          <p class="empty">Ключевых показателей пока нет.</p>
        </article>
      )}
    </section>

    <section class="profile-panel" id="profile-panel-records" data-profile-panel="records" aria-label="Приёмы и документы" hidden>
      <section class="section-grid profile-records-grid">
        <article class="card">
          <h2>Последние документы</h2>
          <div class="stack">
            {documents.slice(0, 4).map((document) => (
              <a class="soft-row compact" href={document.href}>
                <span>{formatDateShort(document.date)} · {document.linkStatusLabel}</span>
                <strong>{document.displayName || document.fileName}</strong>
              </a>
            ))}
            {documents.length === 0 && <p class="empty">Документов пока нет.</p>}
          </div>
        </article>

        <article class="card">
          <h2>История и приёмы</h2>
          <div class="event-list">
            {recentEvents.map((event) => <EventCard event={event} />)}
            {recentEvents.length === 0 && <p class="empty">Приёмов пока нет.</p>}
          </div>
        </article>
      </section>
    </section>
  </div>

  <script>
    const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-profile-tab]"));
    const tabPanels = Array.from(document.querySelectorAll<HTMLElement>("[data-profile-panel]"));
    const tabIds = new Set(tabButtons.map((button) => button.dataset.profileTab).filter(Boolean));

    function activateProfileTab(tabId: string, updateHash = true) {
      const nextTabId = tabIds.has(tabId) ? tabId : "profile";

      for (const button of tabButtons) {
        const isActive = button.dataset.profileTab === nextTabId;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      }

      for (const panel of tabPanels) {
        const isActive = panel.dataset.profilePanel === nextTabId;
        panel.hidden = !isActive;
        panel.classList.toggle("profile-panel-active", isActive);
      }

      if (updateHash) {
        history.replaceState(null, "", `${location.pathname}${location.search}#${nextTabId}`);
      }
    }

    for (const button of tabButtons) {
      button.addEventListener("click", () => {
        activateProfileTab(button.dataset.profileTab || "profile");
      });
    }

    activateProfileTab(location.hash.replace("#", "") || "profile", false);
    window.addEventListener("hashchange", () => activateProfileTab(location.hash.replace("#", "") || "profile", false));

    const form = document.querySelector("[data-weight-form]") as HTMLFormElement | null;
    const status = document.querySelector("[data-weight-form-status]") as HTMLElement | null;
    const configuredUploadApiBase = import.meta.env.PUBLIC_UPLOAD_API_BASE || "";
    const defaultProductionApiBase = "https://babinovifamilybase.vercel.app";
    const apiBase =
      configuredUploadApiBase ||
      (window.location.hostname.endsWith("github.io") ? defaultProductionApiBase : "");
    const isLocalHost = ["127.0.0.1", "localhost"].includes(window.location.hostname);
    const localWeightApiBase = "http://127.0.0.1:4332";

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!status) return;

      const submitButton = form.querySelector("button[type='submit']") as HTMLButtonElement | null;
      const formData = new FormData(form);
      const payload = {
        personId: form.dataset.personId,
        person: form.dataset.personName,
        date: String(formData.get("date") || ""),
        weight: String(formData.get("weight") || ""),
      };

      status.textContent = "Сохраняю...";
      submitButton?.setAttribute("disabled", "disabled");

      try {
        const request = {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        };
        const postWeight = (base: string) => fetch(`${base}/api/metrics/weight`, request);
        let response: Response;

        try {
          response = await postWeight(apiBase);
        } catch (requestError) {
          if (!isLocalHost) throw requestError;
          response = await postWeight(localWeightApiBase);
        }

        if (response.status === 404 && isLocalHost) {
          response = await postWeight(localWeightApiBase);
        }

        const contentType = response.headers.get("content-type") || "";
        if (!contentType.includes("application/json")) {
          throw new Error("Локальный сайт открыт без API. Запустите локальный API сохранения веса.");
        }

        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || "Не удалось сохранить вес.");
        }

        status.textContent = result.local
          ? "Вес сохранён локально. Данные обновляются."
          : "Вес сохранён. После деплоя значение обновится в профиле и показателях.";
      } catch (error) {
        status.textContent =
          error instanceof Error
            ? error.message
            : "Запись веса доступна только на сайте с включённым API.";
      } finally {
        submitButton?.removeAttribute("disabled");
      }
    });
  </script>
</AppLayout>
