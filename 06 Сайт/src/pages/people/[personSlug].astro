---
import AppLayout from "../../layouts/AppLayout.astro";
import EventCard from "../../components/EventCard.astro";
import MetricIcon from "../../components/MetricIcon.astro";
import TaskBoard from "../../components/TaskBoard.astro";
import { ageText, dashboard, formatDate, formatDateShort, pageHref } from "../../lib/ui";

export function getStaticPaths() {
  return dashboard.people.map((person) => ({ params: { personSlug: person.slug }, props: { person } }));
}

const { person } = Astro.props;
const events = dashboard.events.filter((event) => event.personSlug === person.slug);
const tasks = dashboard.tasks.filter((task) => task.personSlug === person.slug);
const documents = dashboard.documents.filter((document) => document.person === person.name);
const keyMetrics = person.keyMetrics || [];
const metricGroups = (dashboard.metricGroups || []).filter((group) => group.person === person.name);
const attentionMetrics = metricGroups
  .filter((group) => ["low", "high"].includes(group.latest?.assessmentStatus))
  .slice(0, 3);
const unlinkedDocuments = documents.filter((document) => !document.isLinkedToEvent).slice(0, 2);
const recentEvents = [...events].sort((a, b) => String(b.date).localeCompare(String(a.date))).slice(0, 5);
type WeightRecord = {
  date?: string;
  displayValue?: string;
};
type WeightMetric = {
  href?: string;
  records?: WeightRecord[];
} | null;
type PersonWithWeight = typeof person & {
  latestWeight?: WeightRecord | null;
  weightMetric?: WeightMetric;
};
const personWithWeight = person as unknown as PersonWithWeight;
const latestWeightData = personWithWeight.latestWeight as any;
const weightMetricData = personWithWeight.weightMetric as { href?: string; records?: WeightRecord[] } | null;
const weightHistory: WeightRecord[] = weightMetricData?.records || [];
const weightMetricHref = weightMetricData?.href;
const latestWeightValue = latestWeightData?.displayValue || "Нет данных";
const latestWeightDateText = latestWeightData?.date ? `на ${formatDateShort(latestWeightData.date)}` : "История пока пустая";
const lastActivity = recentEvents[0]?.date ? formatDateShort(recentEvents[0].date) : "нет событий";
---

<AppLayout title={`${person.name} · Медицинская база`}>
  <section class="profile-hero">
    <div class="profile-identity">
      {person.photo ? (
        <img class="person-avatar hero-avatar" src={pageHref(person.photo)} alt={person.name} />
      ) : (
        <span class="person-avatar hero-avatar fallback" aria-hidden="true">{person.name.slice(0, 1)}</span>
      )}
      <div>
        <p class="eyebrow">Медкарта</p>
        <h1>{person.name}</h1>
        <p>
          {[ageText(person.birthDate), person.bloodType, person.rhFactor, person.importantStatus]
            .filter(Boolean)
            .join(" · ") || "Основная медицинская информация"}
        </p>
        <span class="muted-text">Последняя активность: {lastActivity}</span>
      </div>
    </div>
    <div class="header-actions">
      <a class="button secondary" href={pageHref("/upload")}>Загрузить документ</a>
      <a class="button secondary" href={pageHref("/tasks")}>Добавить задачу</a>
      <a class="button" href={pageHref("/events")}>Открыть историю</a>
    </div>
  </section>

  <nav class="profile-tabs" aria-label={`Разделы профиля ${person.name}`}>
    <a class="active" href="#summary">Сводка</a>
    <a href="#tasks">Задачи {tasks.length}</a>
    <a href="#metrics">Показатели</a>
    <a href="#events">Приёмы</a>
    <a href={pageHref(`/people/${person.slug}/documents`)}>Документы</a>
    <a href="#profile">Профиль</a>
  </nav>

  <section class="profile-dashboard" id="summary">
    <article class="card profile-card">
      <span class="eyebrow">Основное</span>
      {person.photo && <img class="profile-photo" src={pageHref(person.photo)} alt={person.name} />}
      <dl class="details-list">
        <div><dt>Дата рождения</dt><dd>{person.birthDate ? formatDate(person.birthDate) : person.birthDateText || "Не указана"}</dd></div>
        <div><dt>Группа крови</dt><dd>{person.bloodType || "Не указана"}</dd></div>
        <div><dt>Резус-фактор</dt><dd>{person.rhFactor || "Не указан"}</dd></div>
        {person.importantStatus && <div><dt>Статус</dt><dd>{person.importantStatus}</dd></div>}
      </dl>
    </article>

    <div class="profile-main-stack">
      <article class="card care-panel">
        <div class="section-heading compact">
          <div>
            <span class="eyebrow">Сводка</span>
            <h2>Что важно сейчас</h2>
          </div>
        </div>
        <div class="care-list">
          {attentionMetrics.map((group) => (
            <a class:list={["care-item", "metric-care-item", group.latest?.assessmentStatus === "high" ? "danger" : "warning"]} href={group.href}>
              <MetricIcon
                metricName={group.metricLabel}
                status={group.latest?.assessmentStatus}
                statusLabel={group.latest?.compactAssessmentLabel || group.latest?.assessmentLabel}
                class="compact"
              />
              <span>{group.metricLabel}</span>
              <strong>{group.latest?.displayValue}</strong>
              <small>{group.latest?.assessmentLabel || "Проверьте референс"} · {formatDateShort(group.latest?.date)}</small>
            </a>
          ))}
          {tasks.slice(0, 3).map((task) => (
            <a class="care-item warning" href={task.href || task.sourceHref}>
              <span>{task.specialty || "Задача"}</span>
              <strong>{task.actionText}</strong>
              <small>{task.dueDate ? `до ${formatDateShort(task.dueDate)}` : "без даты"}</small>
            </a>
          ))}
          {unlinkedDocuments.map((document) => (
            <a class="care-item violet" href={document.href}>
              <span>Документ на проверку</span>
              <strong>{document.displayName || document.fileName}</strong>
              <small>{formatDateShort(document.date)}</small>
            </a>
          ))}
          {attentionMetrics.length === 0 && tasks.length === 0 && unlinkedDocuments.length === 0 && (
            <p class="empty">Нет активных задач или документов, которые требуют отдельного внимания.</p>
          )}
        </div>
      </article>

      <article class="card">
        <h2>Сводные числа</h2>
      <dl class="mini-stats compact-stats">
        <div><dt>События</dt><dd>{person.eventCount}</dd></div>
        <div><dt>Задачи</dt><dd>{tasks.length}</dd></div>
        <div><dt>Документы</dt><dd>{documents.length}</dd></div>
        <div><dt>Показатели</dt><dd>{metricGroups.length}</dd></div>
      </dl>
      {person.specialtySummary?.length > 0 && (
        <div class="chip-row spacious">
          {person.specialtySummary.map((item) => <span class="chip">{item.label}: {item.count}</span>)}
        </div>
      )}
      </article>
    </div>
  </section>

  <section class="section-grid two">
    <article class="card weight-card" id="profile">
      <h2>Вес</h2>
      <div class="metric-latest">
        <strong>{latestWeightValue}</strong>
        <span>{latestWeightDateText}</span>
      </div>
      {weightHistory.length > 0 && (
        <a class="text-link" href={weightMetricHref}>Открыть историю</a>
      )}
      <form class="weight-form" data-weight-form data-person-id={person.slug} data-person-name={person.name}>
        <label>
          <span class="side-label">Дата</span>
          <input name="date" type="date" required value={new Date().toISOString().slice(0, 10)} />
        </label>
        <label>
          <span class="side-label">Вес, кг</span>
          <input name="weight" type="number" inputmode="decimal" step="0.01" min="0.1" required placeholder="Например, 68.5" />
        </label>
        <button class="button" type="submit">Сохранить вес</button>
        <p class="form-status" data-weight-form-status aria-live="polite"></p>
      </form>
    </article>
    <article class="card">
      <h2>Последние документы</h2>
      <div class="stack">
        {documents.slice(0, 4).map((document) => (
          <a class="soft-row compact" href={document.href}>
            <span>{formatDateShort(document.date)} · {document.linkStatusLabel}</span>
            <strong>{document.displayName || document.fileName}</strong>
          </a>
        ))}
        {documents.length === 0 && <p class="empty">Документов пока нет.</p>}
      </div>
    </article>
  </section>

  <section id="tasks">
    <div class="section-title"><h2>Задачи</h2></div>
    <TaskBoard tasks={tasks} />
  </section>

  {keyMetrics.length > 0 && (
    <section id="metrics">
      <div class="section-title">
        <h2>Ключевые показатели</h2>
        <a class="text-link" href={pageHref("/metrics")}>Все показатели</a>
      </div>
      <div class="metric-grid compact">
        {keyMetrics.map((group) => {
          const latestStatusLabel = group.latest?.compactAssessmentLabel || group.latest?.assessmentLabel || "Нет данных";
          return (
          <article class="card metric-card small">
            <span class:list={["metric-reference-badge", group.latest?.assessmentStatus || "unknown"]}>
              {latestStatusLabel}
            </span>
            <div class="metric-card-header">
              <div class="metric-title-line">
                <MetricIcon metricName={group.metricLabel} status={group.latest?.assessmentStatus} statusLabel={latestStatusLabel} />
                <div>
                  <span class="chip muted">{formatDateShort(group.latest?.date)}</span>
                  <h3><a href={group.href}>{group.metricLabel}</a></h3>
                </div>
              </div>
              <span class="count-badge">{group.count}</span>
            </div>
            <div class="metric-latest">
              <strong>{group.latest?.displayValue || "Нет значения"}</strong>
              {group.trendLabel && <span class:list={["delta-pill", group.trendTone]}>{group.trendLabel}</span>}
            </div>
          </article>
          );
        })}
      </div>
    </section>
  )}

  <section id="events">
    <div class="section-title"><h2>История и приёмы</h2></div>
    <div class="event-list">
      {recentEvents.map((event) => <EventCard event={event} />)}
    </div>
  </section>
  <script>
    const form = document.querySelector("[data-weight-form]") as HTMLFormElement | null;
    const status = document.querySelector("[data-weight-form-status]") as HTMLElement | null;
    const configuredUploadApiBase = import.meta.env.PUBLIC_UPLOAD_API_BASE || "";
    const defaultProductionApiBase = "https://meds-database-site.vercel.app";
    const apiBase =
      configuredUploadApiBase ||
      (window.location.hostname.endsWith("github.io") ? defaultProductionApiBase : "");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!status) return;

      const submitButton = form.querySelector("button[type='submit']") as HTMLButtonElement | null;
      const formData = new FormData(form);
      const payload = {
        personId: form.dataset.personId,
        person: form.dataset.personName,
        date: String(formData.get("date") || ""),
        weight: String(formData.get("weight") || ""),
      };

      status.textContent = "Сохраняю...";
      submitButton?.setAttribute("disabled", "disabled");

      try {
        const response = await fetch(`${apiBase}/api/metrics/weight`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || "Не удалось сохранить вес.");
        }

        status.textContent = "Вес сохранён. После деплоя значение обновится в профиле и показателях.";
        form.reset();
      } catch (error) {
        status.textContent =
          error instanceof Error
            ? error.message
            : "Запись веса доступна только на сайте с включённым API.";
      } finally {
        submitButton?.removeAttribute("disabled");
      }
    });
  </script>
</AppLayout>
