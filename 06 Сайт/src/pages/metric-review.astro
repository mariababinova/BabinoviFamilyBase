---
import AppLayout from "../layouts/AppLayout.astro";
import MetricIcon from "../components/MetricIcon.astro";
import { dashboard, formatDateShort } from "../lib/ui";

const operations = (dashboard.operations || {}) as any;
const metricCandidates = (operations.metricCandidates?.records || []) as any[];
const pending = metricCandidates.filter((candidate) => (candidate.status || "needs_review") === "needs_review");
const resolved = metricCandidates.filter((candidate) => !pending.includes(candidate));
---

<AppLayout title="Проверка показателей · Медицинская база">
  <section class="page-header">
    <p class="eyebrow">На проверке</p>
    <h1>Показатели из документов</h1>
    <p>Здесь подтверждаются только извлечённые строки. В `metrics.json` показатель попадёт после отдельного применения одобренных кандидатов.</p>
  </section>

  <section>
    <div class="section-title">
      <h2>Нужно решение</h2>
      <span>{pending.length}</span>
    </div>
    {pending.length ? (
      <div class="stack-list">
        {pending.map((candidate) => (
          <article class="card">
            <div class="metric-title-line">
              <MetricIcon metricName={candidate.metric_label} status={candidate.status || "needs_review"} />
              <div>
                <p class="eyebrow">{candidate.person || "Не указан"} · {candidate.metric_category || "Показатель"}</p>
                <h3>{candidate.metric_label}</h3>
              </div>
            </div>
            <dl class="details-list">
              <div><dt>Дата</dt><dd>{candidate.date ? formatDateShort(candidate.date) : "Без даты"}</dd></div>
              <div><dt>Значение</dt><dd>{candidate.value_text}{candidate.unit ? ` ${candidate.unit}` : ""}</dd></div>
              <div><dt>Референс</dt><dd>{candidate.reference_text || "Не указан"}</dd></div>
              <div><dt>Уверенность</dt><dd>значение {candidate.value_confidence || candidate.extraction_confidence || "unknown"}, референс {candidate.reference_confidence || "none"}</dd></div>
              <div><dt>Источник</dt><dd>{candidate.source_event_path || candidate.source_draft_path || candidate.source_files?.join(", ") || "Не указан"}</dd></div>
              {candidate.source_section && <div><dt>Место</dt><dd>{candidate.source_section}{candidate.source_line_index !== null ? `, строка ${candidate.source_line_index}` : ""}</dd></div>}
              {candidate.review_warning && <div><dt>Внимание</dt><dd>{candidate.review_warning}</dd></div>}
              <div><dt>Текст</dt><dd>{candidate.source_text || "Нет фрагмента"}</dd></div>
              {candidate.source_window && candidate.source_window !== candidate.source_text && <div><dt>Окно</dt><dd>{candidate.source_window}</dd></div>}
            </dl>
            <form class="review-actions" data-metric-review-form data-candidate-id={candidate.id}>
              <button class="button" type="submit" name="action" value="approve">Подтвердить</button>
              <button class="button secondary" type="submit" name="action" value="reject">Отклонить</button>
              <p class="form-status" data-metric-review-status aria-live="polite"></p>
            </form>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty">Новых показателей на проверке нет.</p>
    )}
  </section>

  {resolved.length > 0 && (
    <section>
      <div class="section-title"><h2>Уже разобрано</h2></div>
      <div class="chip-row">
        {resolved.map((candidate) => (
          <span class="chip">{candidate.status}: {candidate.metric_label}</span>
        ))}
      </div>
    </section>
  )}
  <script>
    const forms = document.querySelectorAll("[data-metric-review-form]");

    forms.forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const htmlForm = form as HTMLFormElement;
        const submitter = (event as SubmitEvent).submitter as HTMLButtonElement | null;
        const status = htmlForm.querySelector("[data-metric-review-status]") as HTMLElement | null;
        const buttons = htmlForm.querySelectorAll("button");
        const action = submitter?.value || "";
        const candidateId = htmlForm.dataset.candidateId || "";

        if (!status || !action || !candidateId) return;

        status.textContent = action === "approve" ? "Подтверждаю..." : "Отклоняю...";
        buttons.forEach((button) => button.setAttribute("disabled", "disabled"));

        const request = {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ candidateId, action }),
        };

        try {
          let response = await fetch("/api/metrics/review", request);
          if (response.status === 404 && ["127.0.0.1", "localhost"].includes(window.location.hostname)) {
            response = await fetch("http://127.0.0.1:4331/api/metrics/review", request);
          }

          const contentType = response.headers.get("content-type") || "";
          if (!contentType.includes("application/json")) {
            throw new Error("Локальный сайт открыт без API. Запустите локальный API проверки показателей.");
          }

          const result = await response.json().catch(() => ({}));
          if (!response.ok) throw new Error(result.error || "Не удалось обновить показатель.");

          const card = htmlForm.closest(".card");
          card?.classList.add("is-resolved");
          status.textContent =
            action === "approve"
              ? "Готово: показатель будет импортирован после применения кандидатов."
              : "Готово: показатель отклонён.";
        } catch (error) {
          status.textContent =
            error instanceof Error
              ? error.message
              : "Не удалось обновить показатель. На локальном просмотре нужен локальный API.";
          buttons.forEach((button) => button.removeAttribute("disabled"));
        }
      });
    });
  </script>
</AppLayout>
