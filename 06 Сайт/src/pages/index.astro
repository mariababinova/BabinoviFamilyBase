---
import AppLayout from "../layouts/AppLayout.astro";
import PersonCard from "../components/PersonCard.astro";
import { dashboard } from "../lib/ui";
---

<AppLayout title="Медицинская база семьи">
  <section class="hero-panel home-hero">
    <div class="home-hero-copy">
      <p class="eyebrow">Семейная медицинская база</p>
      <h1>Медицинская база семьи</h1>
      <p>
        Это общий вход в медицинскую историю семьи. Здесь не нужно помнить, в какой папке лежал анализ
        или когда был приём: сначала выбираем человека, а внутри уже видим документы, события, показатели
        и задачи в контексте его истории.
      </p>
    </div>
    <div class="home-principles" aria-label="Как устроена база">
      <div>
        <strong>Всё начинается с человека</strong>
        <span>У каждого члена семьи свой профиль, своя хронология и свои медицинские документы.</span>
      </div>
      <div>
        <strong>Документы становятся историей</strong>
        <span>Файлы привязываются к датам и событиям, чтобы было понятно, что, когда и почему произошло.</span>
      </div>
      <div>
        <strong>Показатели и задачи помогают не потерять важное</strong>
        <span>Анализы собираются в динамику, а спорные находки сначала уходят на проверку.</span>
      </div>
    </div>
  </section>

  <section>
    <div class="section-title">
      <h2>Члены семьи</h2>
    </div>
    <div class="card-grid home-people-grid">
      {dashboard.people.map((person) => <PersonCard person={person} />)}
    </div>
  </section>
</AppLayout>
