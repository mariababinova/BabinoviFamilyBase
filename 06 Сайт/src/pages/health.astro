---
import AppLayout from "../layouts/AppLayout.astro";
import { dashboard, pageHref } from "../lib/ui";

const people = dashboard.people || [];

const iconPaths = {
  arrow: ["M5 12h14", "m13 6 6 6-6 6"],
  "file-plus": ["M6.5 3.5h7l4 4v13h-11z", "M13.5 3.5v4h4", "M12 12v5", "M9.5 14.5h5"],
  "calendar-plus": ["M5 5.5h14v14H5z", "M8 3.5v4", "M16 3.5v4", "M5 9.5h14", "M12 12.5v4", "M10 14.5h4"],
  flask: ["M9 3.5h6", "M10 3.5v5.2l-4.7 8.1a2.4 2.4 0 0 0 2.1 3.7h9.2a2.4 2.4 0 0 0 2.1-3.7L14 8.7V3.5", "M8.2 15.5h7.6"],
  search: ["M10.8 18.1a7.3 7.3 0 1 0 0-14.6 7.3 7.3 0 0 0 0 14.6Z", "m16 16 4.5 4.5"],
} as const;

type IconName = keyof typeof iconPaths;

const profileConfigs = [
  {
    name: "Александр",
    age: "64 года",
    tone: "blue",
  },
  {
    name: "Артём",
    age: "37 лет",
    tone: "green",
  },
  {
    name: "Маша",
    age: "29 лет",
    tone: "violet",
  },
  {
    name: "Ника",
    age: "меньше года",
    tone: "yellow",
  },
];

const healthProfiles = profileConfigs.map((profile) => ({
  ...profile,
  person: people.find((person) => person.name === profile.name),
}));

const quickActions = [
  {
    title: "Загрузить документ",
    description: "Добавить файл в здоровье",
    href: pageHref("/upload"),
    tone: "blue",
    icon: "file-plus" as IconName,
  },
  {
    title: "Добавить приём или задачу",
    description: "Запланировать визит или задачу",
    href: pageHref("/tasks"),
    tone: "green",
    icon: "calendar-plus" as IconName,
  },
  {
    title: "Добавить показатель",
    description: "Зафиксировать анализ или измерение",
    href: pageHref("/metrics"),
    tone: "violet",
    icon: "flask" as IconName,
  },
  {
    title: "Найти в здоровье",
    description: "Поиск по документам и показателям",
    href: pageHref("/search"),
    tone: "yellow",
    icon: "search" as IconName,
  },
];
---

<AppLayout
  title="Здоровье семьи · База Бабиновых"
  homePortal
  portalTopbarAction={{ href: pageHref("/"), label: "На главную", icon: "home" }}
>
  <div class="portal-health-page">
    <section class="portal-health-hero" aria-labelledby="health-title">
      <h1 id="health-title">Здоровье семьи</h1>
      <p>Профили здоровья, документы, приёмы и показатели по каждому члену семьи.</p>
    </section>

    <section class="portal-health-section" aria-labelledby="health-profiles-title">
      <h2 id="health-profiles-title">Профили здоровья</h2>
      <div class="health-profile-grid">
        {healthProfiles.map((profile) => (
          <a
            class:list={["portal-module-card", "health-profile-card", profile.tone]}
            href={profile.person?.href || pageHref("/health")}
            aria-label={`Открыть профиль здоровья: ${profile.name}`}
          >
            <span class="health-profile-avatar-wrap" aria-hidden={!profile.person?.photo}>
              {profile.person?.photo ? (
                <img class="health-profile-avatar" src={pageHref(profile.person.photo)} alt="" loading="lazy" />
              ) : (
                <span class="health-profile-avatar fallback">{profile.name.slice(0, 1)}</span>
              )}
            </span>
            <h3>{profile.name}</h3>
            <p class="health-profile-age">{profile.age}</p>
            <span class="portal-module-footer health-profile-footer">
              <span class="portal-module-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  {iconPaths.arrow.map((path) => <path d={path} />)}
                </svg>
              </span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="portal-health-section" aria-labelledby="health-actions-title">
      <h2 id="health-actions-title">Быстрые действия</h2>
      <div class="health-action-grid">
        {quickActions.map((action) => (
          <a class:list={["portal-module-card", "health-action-card", action.tone]} href={action.href}>
            <span class:list={["portal-module-icon", "health-action-icon", action.tone]} aria-hidden="true">
              <svg viewBox="0 0 24 24">
                {iconPaths[action.icon].map((path) => <path d={path} />)}
              </svg>
            </span>
            <h3>{action.title}</h3>
            <p>{action.description}</p>
          </a>
        ))}
      </div>
    </section>
  </div>
</AppLayout>
