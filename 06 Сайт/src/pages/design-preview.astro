  .os-nav-glyph::before,
  .os-nav-glyph::after {
    position: absolute;
    content: "";
    border-color: currentColor;
  }

  .os-nav-glyph.home::before {
    inset: 9px 6px 6px;
    border: 1.4px solid currentColor;
    border-top: 0;
    border-radius: 2px;
  }

  .os-nav-glyph.home::after {
    left: 7px;
    top: 5px;
    width: 10px;
    height: 10px;
    border-left: 1.4px solid currentColor;
    border-top: 1.4px solid currentColor;
    transform: rotate(45deg);
  }

  .os-nav-glyph.heart::before {
    left: 7px;
    top: 7px;
    width: 10px;
    height: 10px;
    border: 1.4px solid currentColor;
    border-top-color: transparent;
    border-left-color: transparent;
    transform: rotate(45deg);
    border-radius: 2px;
  }

  .os-nav-glyph.heart::after {
    left: 6px;
    top: 5px;
    width: 12px;
    height: 8px;
    border-top: 1.4px solid currentColor;
    border-left: 1.4px solid currentColor;
    border-right: 1.4px solid currentColor;
    border-radius: 8px 8px 0 0;
  }

  .os-nav-glyph.folder::before {
    left: 6px;
    top: 8px;
    width: 12px;
    height: 9px;
    border: 1.4px solid currentColor;
    border-radius: 2px;
  }

  .os-nav-glyph.folder::after {
    left: 7px;
    top: 6px;
    width: 6px;
    height: 3px;
    border-top: 1.4px solid currentColor;
    border-left: 1.4px solid currentColor;
    border-right: 1.4px solid currentColor;
    border-radius: 2px 2px 0 0;
  }

  .os-nav-glyph.check::before {
    left: 6px;
    top: 7px;
    width: 12px;
    height: 12px;
    border: 1.4px solid currentColor;
    border-radius: 3px;
  }

  .os-nav-glyph.check::after {
    left: 9px;
    top: 11px;
    width: 7px;
    height: 4px;
    border-left: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(-45deg);
  }

  .os-nav-glyph.chart::before {
    left: 7px;
    bottom: 6px;
    width: 2px;
    height: 6px;
    background: currentColor;
    box-shadow: 5px -4px 0 currentColor, 10px -8px 0 currentColor;
    border-radius: 2px;
  }

  .os-nav-glyph.chart::after {
    left: 6px;
    bottom: 5px;
    width: 12px;
    border-bottom: 1.3px solid currentColor;
  }

  .os-nav-glyph.upload::before {
    left: 7px;
    top: 7px;
    width: 10px;
    height: 10px;
    border-left: 1.4px solid currentColor;
    border-top: 1.4px solid currentColor;
    transform: rotate(45deg);
  }

  .os-nav-glyph.upload::after {
