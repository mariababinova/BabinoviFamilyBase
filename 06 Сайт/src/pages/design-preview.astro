---
import "../styles/global.css";
import MetricIcon from "../components/MetricIcon.astro";
import { ageText, dashboard, formatDateShort, pageHref } from "../lib/ui";

const family = dashboard.people.slice(0, 4);
const masha = family.find((person) => person.slug === "masha") || family[2] || family[0];
const recentEvents = [...dashboard.events]
  .sort((a, b) => String(b.date).localeCompare(String(a.date)))
  .slice(0, 4);
const recentDocuments = [...dashboard.documents]
  .sort((a, b) => String(b.date).localeCompare(String(a.date)))
  .slice(0, 4);
const liveTasks = ([...(dashboard.tasks || [])] as any[]).slice(0, 4);

const navItems = [
  { label: "Главная", icon: "home", active: true, count: "" },
  { label: "Медкарты", icon: "heart", active: false, count: "" },
  { label: "Документы", icon: "folder", active: false, count: "" },
  { label: "Задачи", icon: "check", active: false, count: "7" },
  { label: "Показатели", icon: "chart", active: false, count: "" },
  { label: "Загрузки", icon: "upload", active: false, count: "" },
];

const priorityStats = [
  {
    tone: "red",
    metricName: "Ферритин",
    value: "12.8",
    unit: "мкг/л",
    title: "Ферритин Маши ниже нормы",
    meta: "Invitro · 08.05.2025 · референс 15-150",
  },
  {
    tone: "yellow",
    metricName: "",
    value: "01.08",
    unit: "срок",
    title: "Сдать анализы и пройти УЗИ",
    meta: "Эндокринология · связано с приёмом",
  },
  {
    tone: "violet",
    metricName: "",
    value: "1",
    unit: "PDF",
    title: "Документ на проверке",
    meta: "Нужна привязка показателей",
  },
  {
    tone: "blue",
    metricName: "",
    value: "2",
    unit: "приёма",
    title: "На неделе",
    meta: "Подготовить документы заранее",
  },
];

const metrics = [
  { tone: "red", name: "Ферритин", value: "12.8", unit: "мкг/л", date: "08.05.2025", status: "ниже нормы" },
  { tone: "green", name: "Гемоглобин", value: "124", unit: "г/л", date: "08.05.2025", status: "в норме" },
  { tone: "yellow", name: "ТТГ", value: "1.75", unit: "мкМЕ/мл", date: "14.05.2026", status: "на границе" },
  { tone: "green", name: "Витамин D", value: "50", unit: "нг/мл", date: "11.05.2026", status: "в норме" },
];

const plannedTasks = [
  {
    tone: "red",
    title: "Сдать анализы и пройти УЗИ в августе",
    meta: "Маша · до 01.08.2026",
    status: "высокий",
  },
  {
    tone: "yellow",
    title: "Контроль ферритина",
    meta: "Маша · после курса Hema-Plex",
    status: "плановый",
  },
  {
    tone: "green",
    title: "Повторный приём у гинеколога",
    meta: "Маша · 19.05.2026",
    status: "готово",
  },
];

const reviewDocuments = [
  {
    tone: "violet",
    title: "Анализ крови от 08.05.2025",
    meta: "Invitro · извлечены показатели",
    status: "на проверке",
  },
  {
    tone: "green",
    title: "УЗИ щитовидной железы",
    meta: "14.05.2026 · привязано к событию",
    status: "готово",
  },
];

const mobileTabs = ["Сводка", "Задачи", "Показ.", "Ещё"];

function initials(name: string) {
  return name.slice(0, 1).toUpperCase();
}

function personPhoto(person: { photo?: string }) {
  return person.photo ? pageHref(person.photo) : "";
}

function personNote(slug: string) {
  const notes: Record<string, string> = {
    aleksandr: "Онкология · контроль ПСА",
    artem: "Гастроэнтерология · документы",
    masha: "Эндокринология · ферритин",
    nika: "Педиатрия · плановые осмотры",
  };
  return notes[slug] || "Медицинский профиль";
}

function taskTone(priority?: string) {
  if (priority === "high") return "red";
  if (priority === "medium") return "yellow";
  return "blue";
}

const visibleTasks = liveTasks.length
  ? liveTasks.slice(0, 3).map((task) => ({
      tone: taskTone(task.priority),
      href: task.href || pageHref("/tasks"),
      title: task.actionText || task.title,
      meta: `${task.person || "Маша"} · ${task.dueDate ? formatDateShort(task.dueDate) : task.specialty || "план"}`,
      status: task.priority === "high" ? "высокий" : task.priority === "medium" ? "плановый" : task.status || "открыто",
    }))
  : plannedTasks.map((task) => ({
      tone: task.tone,
      href: pageHref("/tasks"),
      title: task.title,
      meta: task.meta,
      status: task.status,
    }));
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Design Preview · Dark Family OS</title>
  </head>
  <body class="os-body">
    <main class="os-page">
      <div class="os-shell">
        <aside class="os-sidebar" aria-label="Навигация">
          <a class="os-brand" href={pageHref("/design-preview")}>
            <span class="os-brand-mark">+</span>
            <span>
              <strong>База Бабиновых</strong>
              <small>Семейный портал</small>
            </span>
          </a>

          <nav class="os-nav" aria-label="Разделы">
            {navItems.map((item) => (
              <a class:list={["os-nav-item", item.active && "active"]} href={pageHref("/design-preview")}>
                <span class:list={["os-nav-glyph", item.icon]} aria-hidden="true"></span>
                <span>{item.label}</span>
                {item.count && <b>{item.count}</b>}
              </a>
            ))}
          </nav>

          <section class="os-family-nav" aria-label="Члены семьи">
            <p>Члены семьи</p>
            {family.map((person) => (
              <a class:list={["os-family-nav-item", person.slug === "masha" && "active"]} href={pageHref("/design-preview")}>
                {personPhoto(person) ? (
                  <img src={personPhoto(person)} alt="" loading="lazy" />
                ) : (
                  <span>{initials(person.name)}</span>
                )}
                <strong>{person.name}</strong>
              </a>
            ))}
          </section>

          <div class="os-sidebar-bottom">
            <a class="os-nav-item" href={pageHref("/design-preview")}>
              <span class="os-nav-glyph settings" aria-hidden="true"></span>
              <span>Настройки</span>
            </a>
            <div class="os-user">
              <img src={pageHref("/people/masha.jpg")} alt="" loading="lazy" />
              <span>
                <strong>Ульяна</strong>
                <small>Администратор</small>
              </span>
            </div>
          </div>
        </aside>

        <section class="os-workspace">
          <header class="os-topbar">
            <label class="os-search">
              <span aria-hidden="true"></span>
              <input type="search" placeholder="Поиск по базе..." aria-label="Поиск по базе" />
              <kbd>⌘ K</kbd>
            </label>
            <div class="os-top-actions">
              <button type="button" aria-label="Уведомления">·</button>
              <button type="button" aria-label="Справка">?</button>
              <img src={pageHref("/people/masha.jpg")} alt="" loading="lazy" />
            </div>
          </header>

          <div class="os-mobile-profile">
            {masha && personPhoto(masha) ? (
              <img src={personPhoto(masha)} alt="" loading="lazy" />
            ) : (
              <span>{masha ? initials(masha.name) : "М"}</span>
            )}
            <div>
              <strong>{masha?.name || "Маша"}</strong>
              <small>{masha ? `${ageText(masha.birthDate)} · ${personNote(masha.slug)}` : "Семейная медкарта"}</small>
            </div>
          </div>

          <div class="os-canvas">
            <section class="os-dashboard" aria-label="Медицинская база семьи">
              <header class="os-heading">
                <div>
                  <h1>Медицинская база семьи</h1>
                  <p>Документы, задачи, показатели и история здоровья по каждому члену семьи.</p>
                </div>
                <div class="os-heading-actions">
                  <a href={pageHref("/upload")}>Загрузить документ</a>
                  <a class="primary" href={pageHref("/tasks")}>Добавить задачу</a>
                </div>
              </header>

              <section class="os-priority-panel" aria-labelledby="priority-title">
                <div class="os-section-head">
                  <div>
                    <span>Операционная сводка</span>
                    <h2 id="priority-title">Что важно сейчас</h2>
                  </div>
                  <a href={pageHref("/tasks")}>Перейти к задачам</a>
                </div>
                <div class="os-priority-grid">
                  {priorityStats.map((item) => (
                    <article class:list={["os-priority-card", item.tone]}>
                      {item.metricName ? (
                        <MetricIcon metricName={item.metricName} tone={item.tone} class="compact" />
                      ) : (
                        <span class="os-status-icon" aria-hidden="true"></span>
                      )}
                      <div class="os-priority-value">
                        <strong>{item.value}</strong>
                        <small>{item.unit}</small>
                      </div>
                      <div class="os-priority-copy">
                        <b>{item.title}</b>
                        <small>{item.meta}</small>
                      </div>
                    </article>
                  ))}
                </div>
              </section>

              <div class="os-main-grid">
                <div class="os-left-stack">
                  <section class="os-panel os-family-panel">
                  <div class="os-section-head compact">
                    <h2>Члены семьи</h2>
                    <a href={pageHref("/overview")}>Все профили</a>
                  </div>
                  <div class="os-people-grid">
                    {family.map((person) => (
                      <article class:list={["os-person-card", person.slug === "masha" && "selected"]}>
                        <div class="os-person-photo">
                          {personPhoto(person) ? (
                            <img src={personPhoto(person)} alt={person.name} loading="lazy" />
                          ) : (
                            <span>{initials(person.name)}</span>
                          )}
                        </div>
                        <div class="os-person-copy">
                          <div>
                            <strong>{person.name}</strong>
                            <small>{ageText(person.birthDate) || "Профиль"}</small>
                          </div>
                          <p>{personNote(person.slug)}</p>
                        </div>
                        <dl>
                          <div>
                            <dt>Событий</dt>
                            <dd>{person.eventCount}</dd>
                          </div>
                          <div>
                            <dt>Задач</dt>
                            <dd>{person.nextTasks?.length || 0}</dd>
                          </div>
                        </dl>
                        <footer>
                          <span>Последнее событие</span>
                          <b>{person.latestEvent ? `${formatDateShort(person.latestEvent.date)} · ${person.latestEvent.specialty}` : "Нет событий"}</b>
                        </footer>
                      </article>
                    ))}
                  </div>
                  </section>

                  <div class="os-lower-grid">
                    <section class="os-panel os-feed-panel">
                      <div class="os-section-head compact">
                        <h2>Лента событий</h2>
                        <a href={pageHref("/events")}>Все события</a>
                      </div>
                      <div class="os-feed">
                        {recentEvents.map((event, index) => (
                          <a class:list={["os-feed-row", index === 0 && "blue", index === 1 && "green", index === 2 && "violet", index === 3 && "yellow"]} href={event.href}>
                            <span class="os-status-icon" aria-hidden="true"></span>
                            <span>
                              <strong>{event.title}</strong>
                              <small>{formatDateShort(event.date)} · {event.specialty} · источник: {event.sourceFileNames?.[0] || "запись"}</small>
                            </span>
                          </a>
                        ))}
                      </div>
                    </section>

                    <section class="os-panel os-feed-panel">
                      <div class="os-section-head compact">
                        <h2>Последние документы</h2>
                        <a href={pageHref("/documents")}>Все документы</a>
                      </div>
                      <div class="os-feed">
                        {recentDocuments.map((document, index) => (
                          <a class:list={["os-feed-row", index === 0 && "violet", index === 1 && "green", index === 2 && "blue", index === 3 && "yellow"]} href={document.href}>
                            <span class="os-status-icon" aria-hidden="true"></span>
                            <span>
                              <strong>{document.displayName || document.fileName}</strong>
                              <small>{formatDateShort(document.date)} · {document.person} · {document.linkStatusLabel}</small>
                            </span>
                          </a>
                        ))}
                      </div>
                    </section>
                  </div>
                </div>

                <aside class="os-summary-stack" aria-label="Сводные виджеты">
                  <section class="os-panel os-list-panel">
                    <div class="os-section-head compact">
                      <h2>Ключевые показатели</h2>
                      <a href={pageHref("/metrics")}>Все</a>
                    </div>
                    <div class="os-list">
                      {metrics.map((metric) => (
                        <a class:list={["os-metric-row", metric.tone]} href={pageHref("/design-preview")}>
                          <MetricIcon metricName={metric.name} tone={metric.tone} class="compact" />
                          <span>
                            <strong>{metric.name}</strong>
                            <small>{metric.value} {metric.unit} · {metric.date}</small>
                          </span>
                          <b>{metric.status}</b>
                        </a>
                      ))}
                    </div>
                  </section>

                  <section class="os-panel os-list-panel">
                    <div class="os-section-head compact">
                      <h2>Ближайшие задачи</h2>
                      <a href={pageHref("/tasks")}>Все</a>
                    </div>
                    <div class="os-list">
                      {visibleTasks.map((task) => (
                        <a class:list={["os-task-row", task.tone]} href={task.href}>
                          <span>
                            <strong>{task.title}</strong>
                            <small>{task.meta}</small>
                          </span>
                          <b>{task.status}</b>
                        </a>
                      ))}
                    </div>
                  </section>

                  <aside class="os-detail-rail os-inline-detail" aria-label="Детали выбранного показателя">
                    <div class="os-detail-head">
                      <div>
                        <MetricIcon metricName="Ферритин" tone="red" class="compact" />
                        <small>Выбранный показатель</small>
                        <h2>Ферритин</h2>
                      </div>
                      <button type="button" aria-label="Закрыть">×</button>
                    </div>

                    <section class="os-detail-value red">
                      <div>
                        <strong>12.8</strong>
                        <span>мкг/л</span>
                      </div>
                      <b>ниже нормы</b>
                    </section>

                    <dl class="os-detail-meta">
                      <div><dt>Дата</dt><dd>08.05.2025</dd></div>
                      <div><dt>Источник</dt><dd>Invitro</dd></div>
                      <div><dt>Референс</dt><dd>15-150 мкг/л</dd></div>
                      <div><dt>Динамика</dt><dd>-0.2 мкг/л</dd></div>
                    </dl>

                    <section class="os-trend-card">
                      <div class="os-detail-section-head">
                        <h3>История значений</h3>
                        <span>12 мес.</span>
                      </div>
                      <svg viewBox="0 0 280 96" role="img" aria-label="Динамика ферритина">
                        <path class="range high" d="M12 20H268" />
                        <path class="range low" d="M12 76H268" />
                        <path class="trend" d="M12 56 C48 50, 58 50, 82 54 C120 62, 142 72, 178 74 C214 78, 238 80, 268 82" />
                        <circle cx="12" cy="56" r="4" />
                        <circle cx="82" cy="54" r="4" />
                        <circle cx="178" cy="74" r="4" />
                        <circle cx="268" cy="82" r="4" />
                      </svg>
                    </section>

                    <section class="os-detail-section">
                      <h3>Связи</h3>
                      <a class="os-detail-link violet" href={pageHref("/documents")}>
                        <strong>Анализ крови от 08.05.2025</strong>
                        <small>Invitro · источник значения</small>
                      </a>
                      <a class="os-detail-link yellow" href={pageHref("/tasks")}>
                        <strong>Контроль ферритина</strong>
                        <small>через 6 недель · задача</small>
                      </a>
                    </section>
                  </aside>

                  <section class="os-panel os-list-panel">
                    <div class="os-section-head compact">
                      <h2>Документы на проверке</h2>
                      <a href={pageHref("/documents")}>Все</a>
                    </div>
                    <div class="os-list">
                      {reviewDocuments.map((document) => (
                        <a class:list={["os-doc-row", document.tone]} href={pageHref("/documents")}>
                          <span>
                            <strong>{document.title}</strong>
                            <small>{document.meta}</small>
                          </span>
                          <b>{document.status}</b>
                        </a>
                      ))}
                    </div>
                  </section>
                </aside>
              </div>

            </section>

            <aside class="os-detail-rail" aria-label="Детали выбранного показателя">
              <div class="os-detail-head">
                <div>
                  <MetricIcon metricName="Ферритин" tone="red" class="compact" />
                  <small>Выбранный показатель</small>
                  <h2>Ферритин</h2>
                </div>
                <button type="button" aria-label="Закрыть">×</button>
              </div>

              <section class="os-detail-value red">
                <div>
                  <strong>12.8</strong>
                  <span>мкг/л</span>
                </div>
                <b>ниже нормы</b>
              </section>

              <dl class="os-detail-meta">
                <div>
                  <dt>Дата</dt>
                  <dd>08.05.2025</dd>
                </div>
                <div>
                  <dt>Источник</dt>
                  <dd>Invitro</dd>
                </div>
                <div>
                  <dt>Референс</dt>
                  <dd>15-150 мкг/л</dd>
                </div>
                <div>
                  <dt>Динамика</dt>
                  <dd>-0.2 мкг/л</dd>
                </div>
              </dl>

              <section class="os-trend-card">
                <div class="os-detail-section-head">
                  <h3>История значений</h3>
                  <span>за 12 месяцев</span>
                </div>
                <svg viewBox="0 0 280 118" role="img" aria-label="Динамика ферритина">
                  <path class="range high" d="M12 24H268" />
                  <path class="range low" d="M12 94H268" />
                  <path class="trend" d="M12 70 C48 64, 58 62, 82 66 C120 74, 142 90, 178 92 C214 95, 238 98, 268 100" />
                  <circle cx="12" cy="70" r="4" />
                  <circle cx="82" cy="66" r="4" />
                  <circle cx="178" cy="92" r="4" />
                  <circle cx="268" cy="100" r="4" />
                </svg>
                <div class="os-trend-scale"><span>15</span><span>150</span></div>
              </section>

              <section class="os-detail-section">
                <h3>Интерпретация</h3>
                <p>Пониженный уровень ферритина может указывать на дефицит железа. Рекомендовано обсудить дальнейшие действия с врачом.</p>
              </section>

              <section class="os-detail-section">
                <h3>Связанные документы</h3>
                <a class="os-detail-link violet" href={pageHref("/documents")}>
                  <strong>Анализ крови от 08.05.2025</strong>
                  <small>Invitro · PDF · источник значения</small>
                </a>
              </section>

              <section class="os-detail-section">
                <h3>Связанные задачи</h3>
                <a class="os-detail-link yellow" href={pageHref("/tasks")}>
                  <strong>Контроль ферритина</strong>
                  <small>через 6 недель · плановый контроль</small>
                </a>
                <a class="os-detail-link blue" href={pageHref("/tasks")}>
                  <strong>Сдать анализы и пройти УЗИ</strong>
                  <small>до 01.08.2026 · следующий шаг</small>
                </a>
              </section>

              <div class="os-detail-actions">
                <a class="primary" href={pageHref("/tasks")}>Создать задачу</a>
                <a href={pageHref("/metrics")}>Открыть показатель</a>
              </div>
            </aside>
          </div>
        </section>
      </div>

      <nav class="os-bottom-nav" aria-label="Нижняя навигация">
        {mobileTabs.map((tab, index) => (
          <a class:list={[index === 0 && "active"]} href={pageHref("/design-preview")}>{tab}</a>
        ))}
      </nav>
    </main>
  </body>
</html>

<style>
  :global(astro-dev-toolbar) {
    display: none !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  :root {
    --os-bg: #0e1217;
    --os-sidebar: #0b0f14;
    --os-surface: #141a22;
    --os-surface-2: #19212b;
    --os-surface-3: #202a36;
    --os-border: rgba(255, 255, 255, 0.08);
    --os-border-strong: rgba(255, 255, 255, 0.14);
    --os-text: #f4f7fa;
    --os-text-2: #a9b4c0;
    --os-muted: #6f7a86;
    --os-blue: #4f8cff;
    --os-green: #4cd77d;
    --os-red: #ff5c5c;
    --os-yellow: #ffc83d;
    --os-violet: #a970ff;
    --os-blue-soft: rgba(79, 140, 255, 0.14);
    --os-green-soft: rgba(76, 215, 125, 0.14);
    --os-red-soft: rgba(255, 92, 92, 0.14);
    --os-yellow-soft: rgba(255, 200, 61, 0.14);
    --os-violet-soft: rgba(169, 112, 255, 0.16);
  }

  .os-body {
    min-height: 100vh;
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(79, 140, 255, 0.08), transparent 34rem),
      radial-gradient(circle at top right, rgba(76, 215, 125, 0.04), transparent 28rem),
      var(--os-bg);
    color: var(--os-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 14px;
    letter-spacing: 0;
    overflow-x: hidden;
  }

  .os-body *,
  .os-body *::before,
  .os-body *::after {
    box-sizing: border-box;
  }

  .os-body a {
    color: inherit;
    text-decoration: none;
  }

  .os-page {
    min-height: 100vh;
    padding: 1rem;
  }

  .os-shell {
    width: min(100%, 1510px);
    min-height: calc(100vh - 2rem);
    display: grid;
